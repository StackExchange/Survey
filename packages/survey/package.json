{
	"name": "survey",
	"version": "0.0.0",
	"private": true,
	"description": "Tooling for updating the Stack Overflow Developer Survey in Qualtrics, as well as creating a preview.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"gen:types": "tsx scripts/gen-types.ts",
		"validate:questions": "tsx scripts/validate-schema.ts questions",
		"validate:survey": "tsx scripts/validate-schema.ts survey",
		"validate:cross": "tsx scripts/validate.ts",
		"validate": "npm run validate:questions && npm run validate:survey && npm run validate:cross"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.6.2",
		"ajv": "^8.20.0",
		"json-schema-to-typescript": "^15.0.4",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tsx": "^4.21.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.10"
	},
	"dependencies": {
		"@dnd-kit/svelte": "^0.4.0",
		"marked": "^18.0.4",
		"yaml": "^2.9.0"
	}
}
